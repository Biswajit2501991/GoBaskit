# Supabase Postgres connection strings.
# Get these from Supabase: Connect button (or Project Settings -> Database).
# Replace [PROJECT-REF], [REGION], and [YOUR-PASSWORD] with your real values (no surrounding quotes needed in Vercel).
# DATABASE_URL = transaction pooler (port 6543), used by the app at runtime.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = session pooler (port 5432), used for prisma migrate/seed.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
JWT_SECRET="change-this-in-production"
ADMIN_EMAIL="admin@gobaskit.com"
ADMIN_PASSWORD="admin123"
WHATSAPP_NUMBER="919046370119"
# Delivery charge is tiered by order value (see constants/index.ts DELIVERY_SLABS).
MIN_ORDER_VALUE="100"
NEXT_PUBLIC_WHATSAPP_NUMBER="919046370119"
NEXT_PUBLIC_STORE_NAME="GoBaskit"
NEXT_PUBLIC_SITE_URL="https://www.gobaskitkaro.com"
# Comma-separated serviceable delivery PIN codes.
NEXT_PUBLIC_SERVICEABLE_PINS="723131,723132,723133"
