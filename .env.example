# Supabase Postgres connection strings.
# Get these from Supabase: Connect button (or Project Settings -> Database).
# Replace [PROJECT-REF], [REGION], and [YOUR-PASSWORD] with your real values (no surrounding quotes needed in Vercel).
# DATABASE_URL = transaction pooler (port 6543), used by the app at runtime.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL = session pooler (port 5432), used for prisma migrate/seed.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
JWT_SECRET="change-this-in-production"
ADMIN_EMAIL="admin@gobaskit.com"
ADMIN_PASSWORD="admin123"
WHATSAPP_NUMBER="919046370119"
# Meta WhatsApp Cloud API (inbound auto-verify webhook)
# Callback URL: https://gobaskitkaro.com/api/webhooks/whatsapp
# WHATSAPP_VERIFY_TOKEN="your-hub-verify-token"
# WHATSAPP_APP_SECRET="your-meta-app-secret"
# WHATSAPP_ACCESS_TOKEN="optional-for-ack-replies"
# WHATSAPP_PHONE_NUMBER_ID="optional-cloud-api-phone-number-id"
# Delivery charge is tiered by order value (see constants/index.ts DELIVERY_SLABS).
MIN_ORDER_VALUE="100"
NEXT_PUBLIC_WHATSAPP_NUMBER="919046370119"
NEXT_PUBLIC_STORE_NAME="GoBaskit"
NEXT_PUBLIC_SITE_URL="https://www.gobaskitkaro.com"
# Optional: POST endpoint for bulk-cancel SMS ({ mobile, message })
# SMS_WEBHOOK_URL="https://your-sms-provider.example/send"
# Secret for /api/cron/purge-archived-orders (health-check uses this every 30 min)
# CRON_SECRET="change-me-in-production"

# --- Railway deploy (app on Railway, DB on Supabase) ---
# Set the same DATABASE_URL / DIRECT_URL as above in Railway Variables.
# NEXT_PUBLIC_SITE_URL should be your Railway URL or custom domain (e.g. https://www.gobaskitkaro.com).
# Railway injects PORT automatically — do not hardcode it.
# Uploads: attach a Railway Volume mounted at /app/public/uploads (ephemeral disk otherwise).
# Comma-separated serviceable delivery PIN codes.
NEXT_PUBLIC_SERVICEABLE_PINS="723131,723132,723133"
# Action Plus Gym membership lookup (server-side only).
# ACTION_PLUS_API_BASE_URL="https://app.gymactionplus.com"
# APG_GYM_ID="48815df4-6144-40dd-bbd6-91fd8522d1ff"
# MEMBER_STATUS_PUBLIC_API_KEY=""

# Web Push for admin background new-order alerts (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@gobaskitkaro.com"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
