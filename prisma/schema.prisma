generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum PaymentMethod {
  COD
  QR_ON_DELIVERY
}

enum StaffRole {
  SUPER_ADMIN
  MANAGER
  ORDER_MANAGER
  INVENTORY_MANAGER
  DELIVERY_MANAGER
  CUSTOMER_SUPPORT
  FINANCE
  MARKETING
  READ_ONLY
  CUSTOM
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?   @map("image_url")
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  price       Float
  actualPrice Float?        @map("actual_price")
  unit        String
  stock       Int           @default(0)
  status      ProductStatus @default(ACTIVE)
  imageUrl    String?       @map("image_url")
  discount    Float         @default(0)
  isFeatured  Boolean       @default(false) @map("is_featured")
  isVisible   Boolean       @default(true) @map("is_visible")
  categoryId  String        @map("category_id")
  category    Category      @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([isFeatured, isVisible])
  @@map("products")
}

model Customer {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  mobile           String
  alternateMobile  String?  @map("alternate_mobile")
  houseNumber      String   @map("house_number")
  street           String
  area             String
  landmark         String?
  city             String
  state            String
  pincode          String
  orders           Order[]
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("customers")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Float
  deliveryCharge  Float         @default(0) @map("delivery_charge")
  grandTotal      Float         @map("grand_total")
  paymentMethod   PaymentMethod @map("payment_method")
  deliveryNotes   String?       @map("delivery_notes")
  orderSource     String        @default("website") @map("order_source")
  customerLat     Float?        @map("customer_lat")
  customerLng     Float?        @map("customer_lng")
  assignedStaffId String?       @map("assigned_staff_id")
  assignedStaff   StaffAccount? @relation("AssignedOrders", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  lockedAt        DateTime?     @map("locked_at")
  priority        OrderPriority @default(NORMAL)
  adminNotes      String?       @map("admin_notes")
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([assignedStaffId])
  @@index([priority, createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id        String        @id @default(cuid())
  orderId   String        @map("order_id")
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  staffId   String?       @map("staff_id")
  staff     StaffAccount? @relation("OrderStatusChanges", fields: [staffId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model AdminNotification {
  id         String        @id @default(cuid())
  staffId    String?       @map("staff_id")
  staff      StaffAccount? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  entityType String?       @map("entity_type")
  entityId   String?       @map("entity_id")
  readAt     DateTime?     @map("read_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([staffId, readAt, createdAt])
  @@index([createdAt])
  @@map("admin_notifications")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  quantity    Int
  unitPrice   Float   @map("unit_price")
  unit        String
  totalPrice  Float   @map("total_price")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

model Upload {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@map("uploads")
}

model StaffAccount {
  id              String    @id @default(cuid())
  mobile          String    @unique
  email           String?   @unique
  name            String
  role            StaffRole @default(READ_ONLY)
  passwordHash    String    @map("password_hash")
  permissions     Json      @default("[]")
  assignedCity    String?   @map("assigned_city")
  assignedAreas   Json      @default("[]") @map("assigned_areas")
  latitude        Float?
  longitude       Float?
  deliveryRadius  Float?    @map("delivery_radius_km")
  active          Boolean   @default(true)
  deletedAt       DateTime? @map("deleted_at")
  lastLogin       DateTime? @map("last_login")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  refreshTokens     StaffRefreshToken[]
  auditLogs         AuditLog[]              @relation("AuditActor")
  assignedOrders    Order[]                 @relation("AssignedOrders")
  orderStatusChanges OrderStatusHistory[]   @relation("OrderStatusChanges")
  notifications     AdminNotification[]

  @@index([mobile])
  @@index([role, active])
  @@index([deletedAt])
  @@map("staff_accounts")
}

model StaffRefreshToken {
  id         String       @id @default(cuid())
  staffId    String       @map("staff_id")
  staff      StaffAccount @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tokenHash  String       @map("token_hash")
  expiresAt  DateTime     @map("expires_at")
  rememberMe Boolean      @default(false) @map("remember_me")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([staffId])
  @@index([expiresAt])
  @@map("staff_refresh_tokens")
}

model StaffLoginAttempt {
  id        String   @id @default(cuid())
  mobile    String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile, createdAt])
  @@map("staff_login_attempts")
}

model AuditLog {
  id        String        @id @default(cuid())
  staffId   String?       @map("staff_id")
  staff     StaffAccount? @relation("AuditActor", fields: [staffId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?       @map("entity_id")
  meta      Json?
  ip        String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([staffId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
