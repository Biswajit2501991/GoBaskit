generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum PaymentMethod {
  COD
  QR_ON_DELIVERY
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
}

enum OrderDiscountType {
  NONE
  COUPON
  MEMBERSHIP
}

enum StaffRole {
  SUPER_ADMIN
  MANAGER
  ORDER_MANAGER
  INVENTORY_MANAGER
  DELIVERY_MANAGER
  CUSTOMER_SUPPORT
  FINANCE
  MARKETING
  READ_ONLY
  CUSTOM
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?   @map("image_url")
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  details     String        @default("") @map("details")
  price       Float
  actualPrice Float?        @map("actual_price")
  unit        String
  stock            Int           @default(0)
  stockBaseline    Int           @default(0) @map("stock_baseline")
  lowStockNotifiedAt DateTime?   @map("low_stock_notified_at")
  status      ProductStatus @default(ACTIVE)
  imageUrl    String?       @map("image_url")
  discount    Float         @default(0)
  isFeatured  Boolean       @default(false) @map("is_featured")
  isVisible   Boolean       @default(true) @map("is_visible")
  hasVariants Boolean       @default(false) @map("has_variants")
  /** 1–5 Health Star Rating; null = not set (hidden on storefront). */
  healthStarRating Int?     @map("health_star_rating")
  categoryId  String        @map("category_id")
  category    Category      @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  variants    ProductVariant[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([isFeatured, isVisible])
  @@index([stock])
  @@map("products")
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand       String   @default("")
  variantName String   @default("") @map("variant_name")
  details     String   @default("") @map("details")
  weight      String   @default("")
  unit        String   @default("")
  price       Float
  mrp         Float?
  discount    Float    @default(0)
  sku         String?
  barcode     String?
  stock       Int      @default(0)
  stockBaseline Int    @default(0) @map("stock_baseline")
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  /** 1–5 Health Star Rating for this option; null falls back to product rating. */
  healthStarRating Int? @map("health_star_rating")
  // Reserved for future variant-specific data (colour, flavour, gst, supplier,
  // expiry, nutrition, bundle/subscription config, etc.) without schema changes.
  attributes  Json?
  orderItems  OrderItem[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([productId, sortOrder])
  @@index([productId, isActive])
  @@map("product_variants")
}

enum WhatsAppVerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
}

model Customer {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  mobile           String
  alternateMobile  String?  @map("alternate_mobile")
  houseNumber      String   @map("house_number")
  street           String
  area             String
  landmark         String?
  city             String
  state            String
  pincode          String
  isWhatsappVerified Boolean @default(false) @map("is_whatsapp_verified")
  verifiedAt       DateTime? @map("verified_at")
  verifiedById     String?  @map("verified_by")
  verifiedBy       StaffAccount? @relation("CustomerVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  orders           Order[]
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([mobile])
  @@map("customers")
}

model CustomerMobile {
  id                 String   @id @default(cuid())
  mobile             String   @unique
  isWhatsappVerified Boolean  @default(false) @map("is_whatsapp_verified")
  verifiedAt         DateTime? @map("verified_at")
  verifiedById       String?  @map("verified_by")
  verifiedBy         StaffAccount? @relation("CustomerMobileVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  passwordHash       String?  @map("password_hash")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedAt           DateTime? @map("locked_at")
  verifications      WhatsAppVerification[]
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("customer_mobiles")
}

model WhatsAppVerification {
  id               String                     @id @default(cuid())
  customerMobileId String                     @map("customer_mobile_id")
  customerMobile   CustomerMobile             @relation(fields: [customerMobileId], references: [id], onDelete: Cascade)
  mobile           String
  verificationCode String                     @map("verification_code")
  status           WhatsAppVerificationStatus @default(PENDING)
  customerName     String?                    @map("customer_name")
  createdAt        DateTime                   @default(now()) @map("created_at")
  expiresAt        DateTime                   @map("expires_at")
  verifiedAt       DateTime?                  @map("verified_at")
  verifiedById     String?                    @map("verified_by")
  verifiedBy       StaffAccount?              @relation("WhatsAppVerificationApprovedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([mobile, status])
  @@index([verificationCode])
  @@index([status, createdAt])
  @@map("whatsapp_verifications")
}

model VerificationAuditLog {
  id             String   @id @default(cuid())
  mobile         String?
  verificationId String?  @map("verification_id")
  action         String
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id")
  ip             String?
  userAgent      String?  @map("user_agent")
  meta           Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([mobile, createdAt])
  @@index([verificationId])
  @@map("verification_audit_logs")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Float
  deliveryCharge  Float         @default(0) @map("delivery_charge")
  discountAmount  Float         @default(0) @map("discount_amount")
  discountType    OrderDiscountType @default(NONE) @map("discount_type")
  couponCode      String?       @map("coupon_code")
  membershipMemberId String?    @map("membership_member_id")
  grandTotal      Float         @map("grand_total")
  paymentMethod   PaymentMethod @map("payment_method")
  deliveryNotes   String?       @map("delivery_notes")
  orderSource     String        @default("website") @map("order_source")
  customerLat     Float?        @map("customer_lat")
  customerLng     Float?        @map("customer_lng")
  assignedStaffId String?       @map("assigned_staff_id")
  assignedStaff   StaffAccount? @relation("AssignedOrders", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  lockedAt        DateTime?     @map("locked_at")
  priority        OrderPriority @default(NORMAL)
  adminNotes      String?       @map("admin_notes")
  stockReserved   Boolean       @default(false) @map("stock_reserved")
  archivedAt           DateTime?     @map("archived_at")
  customerVisibleUntil DateTime?     @map("customer_visible_until")
  purgeAt              DateTime?     @map("purge_at")
  cancelNotice         String?       @map("cancel_notice")
  smsSentAt            DateTime?     @map("sms_sent_at")
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([assignedStaffId])
  @@index([priority, createdAt])
  @@index([archivedAt, purgeAt])
  @@map("orders")
}

model CustomerNotice {
  id        String   @id @default(cuid())
  mobile    String
  orderId   String?  @map("order_id")
  message   String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile, expiresAt])
  @@map("customer_notices")
}

model OrderStatusHistory {
  id        String        @id @default(cuid())
  orderId   String        @map("order_id")
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  staffId   String?       @map("staff_id")
  staff     StaffAccount? @relation("OrderStatusChanges", fields: [staffId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model AdminNotification {
  id         String        @id @default(cuid())
  staffId    String?       @map("staff_id")
  staff      StaffAccount? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  entityType String?       @map("entity_type")
  entityId   String?       @map("entity_id")
  readAt     DateTime?     @map("read_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([staffId, readAt, createdAt])
  @@index([createdAt])
  @@map("admin_notifications")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  variantId   String? @map("variant_id")
  productName String  @map("product_name")
  quantity    Int
  unitPrice   Float   @map("unit_price")
  unit        String
  totalPrice  Float   @map("total_price")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@map("order_items")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

model Upload {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@map("uploads")
}

model StaffAccount {
  id              String    @id @default(cuid())
  mobile          String    @unique
  email           String?   @unique
  name            String
  role            StaffRole @default(READ_ONLY)
  passwordHash    String    @map("password_hash")
  permissions     Json      @default("[]")
  assignedCity    String?   @map("assigned_city")
  assignedAreas   Json      @default("[]") @map("assigned_areas")
  latitude        Float?
  longitude       Float?
  deliveryRadius  Float?    @map("delivery_radius_km")
  active          Boolean   @default(true)
  deletedAt       DateTime? @map("deleted_at")
  lastLogin       DateTime? @map("last_login")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  refreshTokens     StaffRefreshToken[]
  auditLogs         AuditLog[]              @relation("AuditActor")
  assignedOrders    Order[]                 @relation("AssignedOrders")
  orderStatusChanges OrderStatusHistory[]   @relation("OrderStatusChanges")
  notifications     AdminNotification[]
  pushSubscriptions StaffPushSubscription[]
  verifiedCustomers Customer[]              @relation("CustomerVerifiedBy")
  verifiedCustomerMobiles CustomerMobile[]  @relation("CustomerMobileVerifiedBy")
  whatsappVerificationsApproved WhatsAppVerification[] @relation("WhatsAppVerificationApprovedBy")
  learningNotesCreated LearningNote[] @relation("LearningNoteAuthor")
  learningNotesUpdated LearningNote[] @relation("LearningNoteUpdater")

  @@index([mobile])
  @@index([role, active])
  @@index([deletedAt])
  @@map("staff_accounts")
}

model StaffPushSubscription {
  id        String       @id @default(cuid())
  staffId   String       @map("staff_id")
  staff     StaffAccount @relation(fields: [staffId], references: [id], onDelete: Cascade)
  endpoint  String       @unique
  p256dh    String
  auth      String
  userAgent String?      @map("user_agent")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([staffId])
  @@map("staff_push_subscriptions")
}

model StaffRefreshToken {
  id         String       @id @default(cuid())
  staffId    String       @map("staff_id")
  staff      StaffAccount @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tokenHash  String       @map("token_hash")
  expiresAt  DateTime     @map("expires_at")
  rememberMe Boolean      @default(false) @map("remember_me")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([staffId])
  @@index([expiresAt])
  @@map("staff_refresh_tokens")
}

model StaffLoginAttempt {
  id        String   @id @default(cuid())
  mobile    String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile, createdAt])
  @@map("staff_login_attempts")
}

model AuditLog {
  id        String        @id @default(cuid())
  staffId   String?       @map("staff_id")
  staff     StaffAccount? @relation("AuditActor", fields: [staffId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?       @map("entity_id")
  meta      Json?
  ip        String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([staffId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Coupon {
  id                  String             @id @default(cuid())
  couponCode          String             @unique @map("coupon_code")
  discountType        CouponDiscountType @map("discount_type")
  discountValue       Float              @map("discount_value")
  maxDiscount         Float?             @map("max_discount")
  minimumOrder        Float              @default(0) @map("minimum_order")
  startDate           DateTime?          @map("start_date")
  expiryDate          DateTime?          @map("expiry_date")
  status              CouponStatus       @default(ACTIVE)
  usageLimitPerMobile Int                @default(3) @map("usage_limit_per_mobile")
  totalUsageLimit     Int?               @map("total_usage_limit")
  description         String             @default("")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  usages              CouponUsage[]

  @@index([status, expiryDate])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String   @map("coupon_id")
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  mobile         String
  orderId        String   @map("order_id")
  discountAmount Float    @map("discount_amount")
  usedAt         DateTime @default(now()) @map("used_at")

  @@index([couponId, mobile])
  @@index([orderId])
  @@index([mobile, usedAt])
  @@map("coupon_usage")
}

model MembershipDiscountUsage {
  id             String   @id @default(cuid())
  mobile         String
  memberId       String?  @map("member_id")
  orderId        String   @map("order_id")
  discountAmount Float    @map("discount_amount")
  usedAt         DateTime @default(now()) @map("used_at")

  @@index([mobile, usedAt])
  @@index([orderId])
  @@map("membership_discount_usage")
}

model DiscountLog {
  id             String            @id @default(cuid())
  orderId        String?           @map("order_id")
  mobile         String?
  couponCode     String?           @map("coupon_code")
  membership     Boolean           @default(false)
  discountAmount Float             @default(0) @map("discount_amount")
  discountType   OrderDiscountType @default(NONE) @map("discount_type")
  status         String
  appliedBy      String            @default("system") @map("applied_by")
  meta           Json?
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([orderId])
  @@index([mobile, createdAt])
  @@index([createdAt])
  @@map("discount_logs")
}

/** Shared how-to notes for the admin team (Learning menu). */
model LearningNote {
  id          String       @id @default(cuid())
  title       String
  body        String       @db.Text
  authorId    String?      @map("author_id")
  author      StaffAccount? @relation("LearningNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  updatedById String?      @map("updated_by_id")
  updatedBy   StaffAccount? @relation("LearningNoteUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([updatedAt])
  @@map("learning_notes")
}
